# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=TimeWarden

# JWT — change the key for production!
JWT_KEY=ChangeME123!ChangeME123!VeryLongSecure64CharTokenChangeME!!!ChangeME123!ChangeME123!VeryLongSecure64CharTokenChangeME!!!ChangeME123!ChangeME123!VeryLongSecure64CharTokenChangeME!!!
JWT_ISSUER=http://localhost
JWT_AUDIENCE=http://localhost
JWT_TOKEN_LIFETIME=120

# CORS — comma-separated origins for the reverse proxy's domain
CORS_ORIGINS=https://yourdomain.com

# Port exposed on the host (for your reverse proxy to target)
API_PORT=5062

# Directory where the built client files are placed (for Caddy to serve)
CLIENT_OUTPUT=./client-dist

# Client — API base URL for the Vite frontend
VITE_API_URL=http://localhost:5062
